NODE_ENV=development
APP_HOST=127.0.0.1
APP_PORT=4000
APP_SHUTDOWN_TIMEOUT_MS=10000
APP_JSON_LIMIT=1mb
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=financial_audit
MONGODB_MIN_POOL_SIZE=1
MONGODB_MAX_POOL_SIZE=20
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_RETRY_ATTEMPTS=5
MONGODB_CONNECT_RETRY_BASE_DELAY_MS=500

QUEUE_POLL_INTERVAL_MS=500
QUEUE_IDLE_BACKOFF_MAX_MS=5000
QUEUE_LEASE_DURATION_MS=30000
QUEUE_MAX_ATTEMPTS=3
QUEUE_RETRY_BASE_DELAY_MS=1000

PROCESSING_MODEL_DELAY_MS=400
PROCESSING_WORKER_CONCURRENCY=4
PROCESSING_MIGRATION_BATCH_SIZE=100
PROCESSING_QUEUE_BACKPRESSURE_LIMIT=1000

LOG_LEVEL=info
LOG_SERVICE_NAME=financial-audit-backend
LOG_REDACT_PATHS=req.headers.authorization,req.headers.cookie

